# Google Cloud Platform
GCP_PROJECT_ID=merlin-wallet-prod
GCP_ACCOUNT=your-email@gmail.com
GCP_REGION=europe-west1
GCP_BILLING_ACCOUNT=XXXXXX-XXXXXX-XXXXXX

# Firebase
FIREBASE_PROJECT_ID=merlin-wallet-prod
FIREBASE_HOSTING_SITE=merlin-app

# Artifact Registry
DOCKER_REGISTRY=europe-west1-docker.pkg.dev/merlin-wallet-prod/merlin-docker

# Ethereum RPC
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# AI / LLM
OPENAI_API_KEY=sk-xxxxx
GROK_API_KEY=xxxxx

# WebAuthn
WEBAUTHN_RP_ID=merlin-app.web.app
WEBAUTHN_RP_NAME=Merlin

# App
DEBUG=false
