# Google Cloud Platform
GCP_PROJECT_ID=merlin-wallet-prod
GCP_ACCOUNT=your-email@gmail.com
GCP_REGION=europe-west1
GCP_BILLING_ACCOUNT=XXXXXX-XXXXXX-XXXXXX

# Firebase
FIREBASE_PROJECT_ID=merlin-wallet-prod
FIREBASE_HOSTING_SITE=merlin-app

# Artifact Registry
DOCKER_REGISTRY=europe-west1-docker.pkg.dev/merlin-wallet-prod/merlin-docker

# Ethereum RPC (Alchemy)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# AI / LLM
OPENAI_API_KEY=sk-xxxxx
GROK_API_KEY=xai-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Price Data / Market APIs
MORALIS_API_KEY=xxxxx
COINMARKETCAP_API_KEY=xxxxx
CRYPTOCOMPARE_API_KEY=xxxxx

# ERC-4337 Bundler (Pimlico)
# Required for gasless trades (/trade/quote-gasless).
# Get a key at https://dashboard.pimlico.io/
PIMLICO_API_KEY=pim_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WebAuthn
WEBAUTHN_RP_ID=merlin-app.web.app
WEBAUTHN_RP_NAME=Merlin
WEBAUTHN_ORIGIN=https://merlin-app.web.app

# JWT
JWT_SECRET=generate-a-strong-random-secret

# App
DEBUG=false
